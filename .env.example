# Application configuration.
# Copy to .env and adjust as needed. Real environment variables take precedence
# over values in this file. A missing .env file is not an error.

# Environment: development | production (controls log format).
APP_ENV=development

# HTTP server bind host and port.
HOST=0.0.0.0
PORT=9090

# Log level: debug | info | warn | error.
LOG_LEVEL=info

# Service identity, reported as OpenTelemetry resource attributes.
SERVICE_NAME=llmeval
SERVICE_VERSION=dev

# ---------------------------------------------------------------------------
# OpenTelemetry (optional). Telemetry is a no-op unless an OTLP endpoint is set.
# Uses the standard OTEL_* environment variables.
# ---------------------------------------------------------------------------

# General OTLP/HTTP endpoint for all signals.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Signal-specific endpoints (take precedence over the general endpoint).
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=http://localhost:4318/v1/metrics

# Optional exporter headers (e.g. auth) and protocol.
# OTEL_EXPORTER_OTLP_HEADERS=authorization=Bearer <token>
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
